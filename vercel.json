{
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],

  "routes": [
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/images/(.*)", "dest": "/images/$1" },
    { "src": "/fonts/(.*)", "dest": "/fonts/$1" },
    { "src": "/videos/(.*)", "dest": "/videos/$1" },
    { "src": "/sitemap.xml", "dest": "/sitemap.xml" },
    { "src": "/robots.txt", "dest": "/robots.txt" },
    { "src": "/", "dest": "/index.html" },
    { "src": "/about", "dest": "/index.html" },
    { "src": "/projects", "dest": "/index.html" },
    { "src": "/projects/(.*)", "dest": "/index.html" },
    { "src": "/skills", "dest": "/index.html" },
    { "src": "/contact", "dest": "/index.html" },
    { "src": "/mentions-legales", "dest": "/index.html" },
    { "src": "/privacy-policy", "dest": "/index.html" },
    { "src": "/(.*)", "dest": "/index.html", "status": 404 }
  ]
}
